# Configuração do Supabase (Obrigatório)
# Pegue esses dados no Dashboard do Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://sua-url-do-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anonima-publica

# Conexão direta com Banco de Dados (Para scripts de servidor/backup)
# Pegue em Project Settings > Database > Connection String (Nodejs)
DATABASE_URL=postgresql://postgres:[SUA-SENHA]@[HOST]:6543/postgres

# Configurações Opcionais
# Se usar Vercel/Netlify, essas variáveis são configuradas no painel deles.
